# Alchemy Polygon API key (required for funding-chain tracing)
ALCHEMY_API_KEY=

# Database connection (async driver)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/forensics

# Polling intervals (seconds)
TRADE_POLL_INTERVAL=60
SCORING_INTERVAL=300
CLUSTER_INTERVAL=900
RESOLUTION_INTERVAL=3600

# Large-trade threshold (USD)
LARGE_TRADE_USD=5000

# Insider-score watch threshold (triggers funding trace)
INSIDER_TRACE_THRESHOLD=0.3

# Backend HTTP
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# CORS origin for the frontend dev server
FRONTEND_ORIGIN=http://localhost:5173
